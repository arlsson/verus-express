# ETH/ERC20 desktop runtime config
# Copy to .env or .env.local (ignored by git) and fill your keys.

INFURA_PROJECT_ID=your_infura_project_id
ETHERSCAN_API_KEY=your_etherscan_api_key

# Optional overrides
# ETH_MAINNET_RPC_URL=https://mainnet.infura.io/v3/your_infura_project_id
# ETH_TESTNET_RPC_URL=https://sepolia.infura.io/v3/your_infura_project_id
# ETHERSCAN_MAINNET_URL=https://api.etherscan.io/v2/api
# ETHERSCAN_TESTNET_URL=https://api.etherscan.io/v2/api
