# Desktop runtime config
# Copy this file to `.env` or `.env.local` (gitignored) and set your runtime values.

# VRPC endpoints
VRPC_MAINNET_URL=https://your-vrpc-mainnet-endpoint/
VRPC_TESTNET_URL=https://your-vrpc-testnet-endpoint/
VRPC_VARRR_MAINNET_URL=https://your-vrpc-varrr-endpoint/
VRPC_VDEX_MAINNET_URL=https://your-vrpc-vdex-endpoint/
VRPC_CHIPS_MAINNET_URL=https://your-vrpc-chips-endpoint/

# BTC endpoints
BTC_MAINNET_API_URL=https://your-btc-mainnet-api-endpoint
BTC_TESTNET_API_URL=https://your-btc-testnet-api-endpoint

# Comma-separated endpoint lists
DLIGHT_MAINNET_ENDPOINTS=your-mainnet-dlight-endpoint:8120
DLIGHT_TESTNET_ENDPOINTS=your-testnet-dlight-endpoint:8125
ELECTRUM_MAINNET_ENDPOINTS=https://your-electrum-mainnet-endpoint
ELECTRUM_TESTNET_ENDPOINTS=https://your-electrum-testnet-endpoint

# ETH/ERC20 runtime keys
INFURA_PROJECT_ID=your_infura_project_id
ETHERSCAN_API_KEY=your_etherscan_api_key

# Optional ETH overrides
# ETH_MAINNET_RPC_URL=https://your-eth-mainnet-rpc-endpoint
# ETH_TESTNET_RPC_URL=https://your-eth-testnet-rpc-endpoint
# ETHERSCAN_MAINNET_URL=https://your-etherscan-mainnet-endpoint
# ETHERSCAN_TESTNET_URL=https://your-etherscan-testnet-endpoint
